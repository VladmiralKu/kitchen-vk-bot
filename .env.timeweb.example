# Copy this file to .env on the Timeweb server and fill real values.
# Do not commit .env with real secrets.

POSTGRES_DB=kitchen_bot
POSTGRES_USER=kitchen_bot
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD

# Keep the password here exactly the same as POSTGRES_PASSWORD above.
DATABASE_URL=postgresql+asyncpg://kitchen_bot:CHANGE_ME_LONG_RANDOM_PASSWORD@db:5432/kitchen_bot

VK_TOKEN=vk1.a_replace_me
VK_GROUP_ID=123456789
VK_SECRET=long-random-secret
VK_CONFIRMATION_CODE=abc123
SUPERADMIN_VK_ID=123456789

APP_TIMEZONE=Europe/Kirov
AUTO_SEND_ORDERS=false
TOGGLE_ITEM_READY=true
KITCHEN_MODE=private
KITCHEN_PEER_ID=
STOPS_TTL_HOURS=12
PUBLIC_BASE_URL=https://YOUR_DOMAIN
LOG_LEVEL=INFO
